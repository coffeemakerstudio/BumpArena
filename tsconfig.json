{
	"compilerOptions": {
		"lib": [
			"ES2020"
		],
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowJs": true,
		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"rewriteRelativeImportExtensions": true,
		"declaration": true,
		"emitDeclarationOnly": false,
		"outDir": "dist"
	},
	"include": [
		"arena.ts",
		"test/*",
		"bench/*"
	]
}
